# Plantilla de variables de entorno del backend Rizoma.
# Copiá este archivo a ".env" y completá los valores reales. NO commitees el .env.

# Base de datos Neon (usar el endpoint DIRECTO, sin -pooler)
DB_URL=jdbc:postgresql://TU-HOST.neon.tech/neondb?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=tu-password-de-neon

# Panel admin
ADMIN_USER=admin
ADMIN_PASSWORD=una-password-fuerte

# WhatsApp destino de Rizoma (formato internacional, sin +)
WHATSAPP_DESTINO=5492215346770

# CORS: URL del frontend (en local http://localhost:4200)
CORS_ORIGINS=https://tu-frontend.onrender.com
